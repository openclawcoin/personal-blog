---
import BaseLayout from "../layouts/BaseLayout.astro";
import { siteConfig } from "../site.config";
---

<BaseLayout title={`写作台 | ${siteConfig.title}`} description="在前端直接写作并发布到 GitHub 仓库。">
  <section class="writer-page">
    <div class="writer-head">
      <h1>前端写作台</h1>
      <p>在这里写完后可直接提交到 GitHub 仓库的 `src/content/blog/`，触发静态站自动更新。</p>
    </div>

    <form class="writer-form" data-writer-form>
      <section class="writer-card">
        <h2>仓库配置</h2>

        <label>
          GitHub Token（建议使用 Fine-grained Token）
          <input data-token type="password" placeholder="ghp_xxx / github_pat_xxx" autocomplete="off" required />
        </label>

        <div class="writer-grid">
          <label>
            Owner
            <input data-owner type="text" placeholder="your-github-name" required />
          </label>

          <label>
            Repo
            <input data-repo type="text" placeholder="personal-blog" required />
          </label>

          <label>
            Branch
            <input data-branch type="text" value="main" required />
          </label>
        </div>

        <label class="check-row">
          <input data-save-token type="checkbox" />
          记住 Token（仅保存在当前浏览器）
        </label>
      </section>

      <section class="writer-card">
        <h2>文章内容</h2>

        <label>
          标题
          <input data-title type="text" placeholder="比如：今天学会了什么" required />
        </label>

        <label>
          简介
          <input data-description type="text" placeholder="一句话概括这篇文章" required />
        </label>

        <div class="writer-grid">
          <label>
            发布日期
            <input data-date type="date" required />
          </label>

          <label>
            标签（逗号分隔）
            <input data-tags type="text" placeholder="daily, notes" />
          </label>

          <label class="check-row">
            <input data-draft type="checkbox" />
            设为草稿（draft: true）
          </label>
        </div>

        <label>
          正文（Markdown）
          <div class="md-toolbar" data-md-toolbar>
            <button type="button" data-md-action="h2">H2</button>
            <button type="button" data-md-action="h3">H3</button>
            <button type="button" data-md-action="bold">粗体</button>
            <button type="button" data-md-action="italic">斜体</button>
            <button type="button" data-md-action="link">链接</button>
            <button type="button" data-md-action="image">图片</button>
            <button type="button" data-md-action="code">代码块</button>
            <button type="button" data-md-action="quote">引用</button>
            <button type="button" data-md-action="ul">无序列表</button>
            <button type="button" data-md-action="ol">有序列表</button>
            <button type="button" data-md-action="hr">分割线</button>
          </div>
          <textarea data-body rows="16" placeholder="在这里写正文。支持图片/音频/视频 HTML 代码。" required></textarea>
        </label>

        <div class="action-row">
          <button type="button" class="ghost" data-preview-file>预览文件名</button>
          <button type="submit" class="primary" data-submit>发布到 GitHub</button>
        </div>

        <p class="writer-path" data-file-path>将生成：`src/content/blog/日期-标题.md`</p>
        <p class="writer-status" data-status>就绪</p>
      </section>

      <section class="writer-card writer-manage">
        <h2>已发布文章管理</h2>

        <div class="manage-head">
          <button type="button" class="ghost" data-load-posts>刷新文章列表</button>
          <p class="writer-mini">读取仓库中的 `src/content/blog/*.md`</p>
        </div>

        <label>
          选择文章
          <select data-post-select>
            <option value="">请先点击“刷新文章列表”</option>
          </select>
        </label>

        <div class="action-row">
          <button type="button" class="ghost" data-load-selected>载入编辑</button>
          <button type="button" class="danger" data-delete-selected>删除文章</button>
          <button type="button" class="ghost" data-exit-edit>退出编辑模式</button>
        </div>

        <p class="writer-mini" data-editing-hint>当前模式：新建文章</p>
      </section>
    </form>

    <section class="writer-card writer-help">
      <h2>个人介绍</h2>
      <p>我是一只爱做梦的虾，热爱 AI、区块链和各种新鲜事物。🦐✨</p>
      <p>我喜欢把每天的学习、踩坑与灵感整理成文章，与大家一起交流成长。🤖💡</p>
      <p>希望这片小小实验室，记录下我一路前行的点点滴滴。🌊📒</p>
    </section>
  </section>
</BaseLayout>

<script is:inline>
(() => {
  const STORAGE = "shrimp.writer.settings.v1";
  const BLOG_DIR = "src/content/blog";

  const form = document.querySelector("[data-writer-form]");
  if (!form) return;

  const nodes = {
    token: form.querySelector("[data-token]"),
    owner: form.querySelector("[data-owner]"),
    repo: form.querySelector("[data-repo]"),
    branch: form.querySelector("[data-branch]"),
    saveToken: form.querySelector("[data-save-token]"),
    title: form.querySelector("[data-title]"),
    description: form.querySelector("[data-description]"),
    date: form.querySelector("[data-date]"),
    tags: form.querySelector("[data-tags]"),
    draft: form.querySelector("[data-draft]"),
    body: form.querySelector("[data-body]"),
    mdToolbar: form.querySelector("[data-md-toolbar]"),
    previewFile: form.querySelector("[data-preview-file]"),
    submit: form.querySelector("[data-submit]"),
    filePath: form.querySelector("[data-file-path]"),
    status: form.querySelector("[data-status]"),
    loadPosts: form.querySelector("[data-load-posts]"),
    postSelect: form.querySelector("[data-post-select]"),
    loadSelected: form.querySelector("[data-load-selected]"),
    deleteSelected: form.querySelector("[data-delete-selected]"),
    exitEdit: form.querySelector("[data-exit-edit]"),
    editingHint: form.querySelector("[data-editing-hint]")
  };

  const requiredNodes = Object.values(nodes);
  if (requiredNodes.some((node) => !node)) return;

  const state = {
    publishing: false,
    loadingPosts: false,
    editingPath: "",
    editingSha: "",
    postEntries: []
  };

  function todayText() {
    return new Date().toISOString().slice(0, 10);
  }

  function slugify(text) {
    return String(text || "")
      .trim()
      .toLowerCase()
      .replace(/[\s/]+/g, "-")
      .replace(/[^\w\u4e00-\u9fa5-]+/g, "")
      .replace(/-+/g, "-")
      .replace(/^-|-$/g, "");
  }

  function normalizeTags(raw) {
    return String(raw || "")
      .split(/[,，\s\n]+/)
      .map((v) => v.trim())
      .filter(Boolean);
  }

  function safeTitle(value) {
    return String(value || "").replace(/"/g, '\\"').trim();
  }

  function stripQuotes(value) {
    const text = String(value || "").trim();
    if (!text) return "";

    if ((text.startsWith('"') && text.endsWith('"')) || (text.startsWith("'") && text.endsWith("'"))) {
      return text.slice(1, -1).replace(/\\"/g, '"');
    }

    return text.replace(/\\"/g, '"');
  }

  function toBase64Unicode(str) {
    const bytes = new TextEncoder().encode(str);
    let binary = "";
    for (const b of bytes) binary += String.fromCharCode(b);
    return btoa(binary);
  }

  function fromBase64Unicode(str) {
    const binary = atob(String(str || "").replace(/\n/g, ""));
    const bytes = Uint8Array.from(binary, (char) => char.charCodeAt(0));
    return new TextDecoder().decode(bytes);
  }

  function encodeRepoPath(path) {
    return path.split("/").map(encodeURIComponent).join("/");
  }

  function getHeaders(token) {
    return {
      Accept: "application/vnd.github+json",
      Authorization: `Bearer ${token}`,
      "X-GitHub-Api-Version": "2022-11-28"
    };
  }

  function setStatus(text, kind = "") {
    nodes.status.textContent = text;
    nodes.status.dataset.type = kind;
  }

  function getPublishedArticleUrl(articleSlug) {
    const pathname = String(window.location.pathname || "/");
    const normalizedPath = pathname.endsWith("/") ? pathname : `${pathname}/`;
    const writeMarker = "/write/";
    const markerIndex = normalizedPath.lastIndexOf(writeMarker);
    const basePath = markerIndex >= 0 ? normalizedPath.slice(0, markerIndex) : "";
    const articlePath = `${basePath}/blog/${articleSlug}/`.replace(/\/{2,}/g, "/");
    return new URL(articlePath, window.location.origin).toString();
  }

  function buildFilename() {
    const date = nodes.date.value || todayText();
    const slug = slugify(nodes.title.value) || `post-${Date.now()}`;
    return `${date}-${slug}.md`;
  }

  function buildNewFilePath() {
    return `${BLOG_DIR}/${buildFilename()}`;
  }

  function buildFrontmatter() {
    const title = safeTitle(nodes.title.value);
    const description = safeTitle(nodes.description.value);
    const date = nodes.date.value || todayText();
    const tags = normalizeTags(nodes.tags.value);
    const draft = Boolean(nodes.draft.checked);

    const tagsYaml = tags.length
      ? tags.map((tag) => `  - ${tag}`).join("\n")
      : "  - notes";

    return [
      "---",
      `title: \"${title}\"`,
      `description: \"${description}\"`,
      `pubDate: ${date}`,
      "tags:",
      tagsYaml,
      `draft: ${draft ? "true" : "false"}`,
      "---",
      ""
    ].join("\n");
  }

  function buildMarkdown() {
    const body = String(nodes.body.value || "").trim();
    return `${buildFrontmatter()}\n${body}\n`;
  }

  function parseMarkdownFile(markdown) {
    const text = String(markdown || "");
    const matched = text.match(/^---\r?\n([\s\S]*?)\r?\n---\r?\n?([\s\S]*)$/);

    const parsed = {
      title: "",
      description: "",
      pubDate: todayText(),
      tags: [],
      draft: false,
      body: text.trim()
    };

    if (!matched) return parsed;

    const frontmatter = matched[1];
    parsed.body = String(matched[2] || "").trim();

    const lines = frontmatter.split(/\r?\n/);
    let readingTags = false;

    for (const line of lines) {
      if (/^\s*tags:\s*$/.test(line)) {
        readingTags = true;
        continue;
      }

      const tagMatched = line.match(/^\s*-\s*(.+)\s*$/);
      if (readingTags && tagMatched) {
        parsed.tags.push(stripQuotes(tagMatched[1]));
        continue;
      }

      if (readingTags && /^\s*$/.test(line)) {
        continue;
      }

      readingTags = false;

      let value = "";
      if ((value = (line.match(/^\s*title:\s*(.+)\s*$/) || [])[1])) {
        parsed.title = stripQuotes(value);
        continue;
      }

      if ((value = (line.match(/^\s*description:\s*(.+)\s*$/) || [])[1])) {
        parsed.description = stripQuotes(value);
        continue;
      }

      if ((value = (line.match(/^\s*pubDate:\s*(.+)\s*$/) || [])[1])) {
        parsed.pubDate = String(stripQuotes(value)).slice(0, 10);
        continue;
      }

      if ((value = (line.match(/^\s*draft:\s*(.+)\s*$/) || [])[1])) {
        parsed.draft = /true/i.test(value);
      }
    }

    if (!parsed.pubDate) parsed.pubDate = todayText();
    return parsed;
  }

  function applyParsedToForm(parsed) {
    nodes.title.value = parsed.title || "";
    nodes.description.value = parsed.description || "";
    nodes.date.value = parsed.pubDate || todayText();
    nodes.tags.value = Array.isArray(parsed.tags) ? parsed.tags.join(", ") : "";
    nodes.draft.checked = Boolean(parsed.draft);
    nodes.body.value = parsed.body || "";
  }

  function refreshPath() {
    if (state.editingPath) {
      nodes.filePath.textContent = `正在编辑：${state.editingPath}`;
      return;
    }

    nodes.filePath.textContent = `将生成：${buildNewFilePath()}`;
  }

  function updateModeUi() {
    if (state.editingPath) {
      nodes.submit.textContent = "保存修改到 GitHub";
      nodes.editingHint.textContent = `当前模式：编辑 ${state.editingPath}`;
    } else {
      nodes.submit.textContent = "发布到 GitHub";
      nodes.editingHint.textContent = "当前模式：新建文章";
    }

    refreshPath();
  }

  function saveSettings() {
    const payload = {
      owner: nodes.owner.value.trim(),
      repo: nodes.repo.value.trim(),
      branch: nodes.branch.value.trim() || "main",
      saveToken: Boolean(nodes.saveToken.checked),
      token: nodes.saveToken.checked ? nodes.token.value.trim() : ""
    };
    localStorage.setItem(STORAGE, JSON.stringify(payload));
  }

  function loadSettings() {
    try {
      const raw = localStorage.getItem(STORAGE);
      if (!raw) return;
      const parsed = JSON.parse(raw);

      if (typeof parsed.owner === "string") nodes.owner.value = parsed.owner;
      if (typeof parsed.repo === "string") nodes.repo.value = parsed.repo;
      if (typeof parsed.branch === "string" && parsed.branch) nodes.branch.value = parsed.branch;
      if (typeof parsed.saveToken === "boolean") nodes.saveToken.checked = parsed.saveToken;
      if (parsed.saveToken && typeof parsed.token === "string") nodes.token.value = parsed.token;
    } catch {
      // ignore
    }
  }

  function getRepoConfig() {
    const token = nodes.token.value.trim();
    const owner = nodes.owner.value.trim();
    const repo = nodes.repo.value.trim();
    const branch = nodes.branch.value.trim() || "main";

    if (!token || !owner || !repo) {
      setStatus("请先填写 Token、Owner、Repo。", "warn");
      return null;
    }

    return { token, owner, repo, branch };
  }

  async function fetchFileSha({ owner, repo, branch, path, headers }) {
    const encodedPath = encodeRepoPath(path);
    const url = `https://api.github.com/repos/${owner}/${repo}/contents/${encodedPath}?ref=${encodeURIComponent(branch)}`;
    const resp = await fetch(url, { headers });

    if (resp.status === 404) return "";

    const data = await resp.json().catch(() => ({}));
    if (!resp.ok) {
      const message = data?.message || `获取文件信息失败（HTTP ${resp.status}）`;
      throw new Error(message);
    }

    return typeof data.sha === "string" ? data.sha : "";
  }

  async function fetchFileContent({ owner, repo, branch, path, headers }) {
    const encodedPath = encodeRepoPath(path);
    const url = `https://api.github.com/repos/${owner}/${repo}/contents/${encodedPath}?ref=${encodeURIComponent(branch)}`;
    const resp = await fetch(url, { headers });

    const data = await resp.json().catch(() => ({}));
    if (!resp.ok) {
      const message = data?.message || `读取文章失败（HTTP ${resp.status}）`;
      throw new Error(message);
    }

    const encoded = typeof data.content === "string" ? data.content : "";
    const markdown = encoded ? fromBase64Unicode(encoded) : "";

    return {
      sha: typeof data.sha === "string" ? data.sha : "",
      markdown
    };
  }

  function renderPostOptions(preferredPath = "") {
    const keepPath = preferredPath || nodes.postSelect.value;
    nodes.postSelect.innerHTML = "";

    if (!state.postEntries.length) {
      const option = document.createElement("option");
      option.value = "";
      option.textContent = "仓库里还没有文章";
      nodes.postSelect.append(option);
      return;
    }

    for (const entry of state.postEntries) {
      const option = document.createElement("option");
      option.value = entry.path;
      option.textContent = entry.name;
      nodes.postSelect.append(option);
    }

    const hasKeep = state.postEntries.some((entry) => entry.path === keepPath);
    nodes.postSelect.value = hasKeep ? keepPath : state.postEntries[0].path;
  }

  function getSelectedEntry() {
    const path = String(nodes.postSelect.value || "");
    if (!path) return null;
    return state.postEntries.find((entry) => entry.path === path) || null;
  }

  async function listPosts({ silent = false, preserveSelection = "" } = {}) {
    if (state.loadingPosts) return;

    const config = getRepoConfig();
    if (!config) return;

    state.loadingPosts = true;
    nodes.loadPosts.disabled = true;

    if (!silent) setStatus("正在读取文章列表...", "loading");

    try {
      const { token, owner, repo, branch } = config;
      const headers = getHeaders(token);
      const encodedDir = encodeRepoPath(BLOG_DIR);
      const url = `https://api.github.com/repos/${owner}/${repo}/contents/${encodedDir}?ref=${encodeURIComponent(branch)}`;
      const resp = await fetch(url, { headers });
      const data = await resp.json().catch(() => []);

      if (!resp.ok) {
        const message = data?.message || `读取列表失败（HTTP ${resp.status}）`;
        throw new Error(message);
      }

      const files = Array.isArray(data)
        ? data.filter((item) => item?.type === "file" && typeof item?.name === "string" && item.name.endsWith(".md"))
        : [];

      files.sort((a, b) => String(b.name).localeCompare(String(a.name), "zh-CN"));

      state.postEntries = files.map((item) => ({
        name: String(item.name || ""),
        path: String(item.path || ""),
        sha: String(item.sha || "")
      }));

      renderPostOptions(preserveSelection);

      if (!silent) {
        setStatus(`已加载 ${state.postEntries.length} 篇文章。`, "ok");
      }
    } catch (error) {
      const message = error instanceof Error ? error.message : "未知错误";
      setStatus(`读取列表失败：${message}`, "error");
    } finally {
      state.loadingPosts = false;
      nodes.loadPosts.disabled = false;
    }
  }

  function startEditing(path, sha = "") {
    state.editingPath = path;
    state.editingSha = sha;
    updateModeUi();
  }

  function stopEditing() {
    state.editingPath = "";
    state.editingSha = "";
    updateModeUi();
  }

  async function loadSelectedPost() {
    const config = getRepoConfig();
    if (!config) return;

    const entry = getSelectedEntry();
    if (!entry) {
      setStatus("请先选择一篇文章。", "warn");
      return;
    }

    setStatus("正在载入文章内容...", "loading");

    try {
      const headers = getHeaders(config.token);
      const file = await fetchFileContent({
        owner: config.owner,
        repo: config.repo,
        branch: config.branch,
        path: entry.path,
        headers
      });

      const parsed = parseMarkdownFile(file.markdown);
      applyParsedToForm(parsed);
      startEditing(entry.path, file.sha || entry.sha);
      setStatus(`已载入：${entry.name}，现在可以编辑并保存。`, "ok");
    } catch (error) {
      const message = error instanceof Error ? error.message : "未知错误";
      setStatus(`载入失败：${message}`, "error");
    }
  }

  async function deleteSelectedPost() {
    const config = getRepoConfig();
    if (!config) return;

    const entry = getSelectedEntry();
    if (!entry) {
      setStatus("请先选择要删除的文章。", "warn");
      return;
    }

    const ok = window.confirm(`确定要删除这篇文章吗？\n${entry.name}`);
    if (!ok) return;

    setStatus("正在删除文章...", "loading");

    try {
      const headers = getHeaders(config.token);
      const path = entry.path;
      const encodedPath = encodeRepoPath(path);
      const sha = entry.sha || (await fetchFileSha({
        owner: config.owner,
        repo: config.repo,
        branch: config.branch,
        path,
        headers
      }));

      if (!sha) {
        throw new Error("未获取到文件 SHA，无法删除。");
      }

      const url = `https://api.github.com/repos/${config.owner}/${config.repo}/contents/${encodedPath}`;
      const resp = await fetch(url, {
        method: "DELETE",
        headers: {
          ...headers,
          "Content-Type": "application/json"
        },
        body: JSON.stringify({
          message: `delete: ${entry.name}`,
          sha,
          branch: config.branch
        })
      });

      const result = await resp.json().catch(() => ({}));
      if (!resp.ok) {
        const message = result?.message || `删除失败（HTTP ${resp.status}）`;
        throw new Error(message);
      }

      if (state.editingPath === path) {
        stopEditing();
      }

      await listPosts({ silent: true });
      setStatus(`已删除：${entry.name}`, "ok");
    } catch (error) {
      const message = error instanceof Error ? error.message : "未知错误";
      setStatus(`删除失败：${message}`, "error");
    }
  }

  function replaceSelection(prefix, suffix, placeholder = "") {
    const textarea = nodes.body;
    const start = textarea.selectionStart;
    const end = textarea.selectionEnd;
    const selected = textarea.value.slice(start, end);
    const center = selected || placeholder;

    const next = `${textarea.value.slice(0, start)}${prefix}${center}${suffix}${textarea.value.slice(end)}`;
    textarea.value = next;

    const selectStart = start + prefix.length;
    const selectEnd = selectStart + center.length;
    textarea.focus();
    textarea.setSelectionRange(selectStart, selectEnd);
  }

  function insertSnippet(snippet) {
    const textarea = nodes.body;
    const start = textarea.selectionStart;
    const end = textarea.selectionEnd;
    textarea.value = `${textarea.value.slice(0, start)}${snippet}${textarea.value.slice(end)}`;
    const cursor = start + snippet.length;
    textarea.focus();
    textarea.setSelectionRange(cursor, cursor);
  }

  function withSelectedLines(mapper) {
    const textarea = nodes.body;
    const value = textarea.value;
    const start = textarea.selectionStart;
    const end = textarea.selectionEnd;

    const lineStart = value.lastIndexOf("\n", Math.max(0, start - 1)) + 1;
    const lineEndIndex = value.indexOf("\n", end);
    const lineEnd = lineEndIndex === -1 ? value.length : lineEndIndex;

    const segment = value.slice(lineStart, lineEnd);
    const lines = segment ? segment.split("\n") : [""];
    const replaced = lines.map((line, index) => mapper(line, index)).join("\n");

    textarea.value = `${value.slice(0, lineStart)}${replaced}${value.slice(lineEnd)}`;
    textarea.focus();
    textarea.setSelectionRange(lineStart, lineStart + replaced.length);
  }

  function applyMarkdownAction(action) {
    switch (action) {
      case "h2":
        withSelectedLines((line) => `## ${line || "小标题"}`);
        break;
      case "h3":
        withSelectedLines((line) => `### ${line || "小标题"}`);
        break;
      case "bold":
        replaceSelection("**", "**", "加粗文字");
        break;
      case "italic":
        replaceSelection("*", "*", "斜体文字");
        break;
      case "link":
        replaceSelection("[", "](https://example.com)", "链接文字");
        break;
      case "image":
        replaceSelection("![", "](https://example.com/image.jpg)", "图片描述");
        break;
      case "code":
        replaceSelection("```\n", "\n```", "在这里写代码");
        break;
      case "quote":
        withSelectedLines((line) => `> ${line || "引用内容"}`);
        break;
      case "ul":
        withSelectedLines((line) => `- ${line || "列表项"}`);
        break;
      case "ol":
        withSelectedLines((line, index) => `${index + 1}. ${line || "列表项"}`);
        break;
      case "hr":
        insertSnippet("\n---\n");
        break;
      default:
        break;
    }
  }

  async function publish() {
    if (state.publishing) return;

    const config = getRepoConfig();
    if (!config) return;

    if (!nodes.title.value.trim() || !nodes.description.value.trim() || !nodes.body.value.trim()) {
      setStatus("标题、简介、正文都需要填写。", "warn");
      return;
    }

    state.publishing = true;
    nodes.submit.disabled = true;

    setStatus(state.editingPath ? "正在保存修改到 GitHub..." : "正在发布到 GitHub...", "loading");

    try {
      const path = state.editingPath || buildNewFilePath();
      const markdown = buildMarkdown();
      const encodedPath = encodeRepoPath(path);
      const headers = getHeaders(config.token);

      const sha = await fetchFileSha({
        owner: config.owner,
        repo: config.repo,
        branch: config.branch,
        path,
        headers
      });

      const payload = {
        message: `${state.editingPath ? "edit" : sha ? "update" : "create"}: ${nodes.title.value.trim()}`,
        content: toBase64Unicode(markdown),
        branch: config.branch
      };

      if (sha) payload.sha = sha;

      const putUrl = `https://api.github.com/repos/${config.owner}/${config.repo}/contents/${encodedPath}`;
      const putResp = await fetch(putUrl, {
        method: "PUT",
        headers: {
          ...headers,
          "Content-Type": "application/json"
        },
        body: JSON.stringify(payload)
      });

      const result = await putResp.json().catch(() => ({}));
      if (!putResp.ok) {
        const message = result?.message || `发布失败（HTTP ${putResp.status}）`;
        throw new Error(message);
      }

      if (state.editingPath) {
        state.editingSha = result?.content?.sha || sha || state.editingSha;
      }

      saveSettings();

      const articleSlug = slugify(path.split("/").pop().replace(/\.md$/, ""));
      const articleUrl = getPublishedArticleUrl(articleSlug);
      const commitUrl = result?.commit?.html_url || "";
      const extra = commitUrl ? `，提交：${commitUrl}` : "";

      await listPosts({ silent: true, preserveSelection: path });
      setStatus(`发布成功，预计部署完成后可访问：${articleUrl}${extra}`, "ok");
    } catch (error) {
      const message = error instanceof Error ? error.message : "未知错误";
      setStatus(`发布失败：${message}`, "error");
    } finally {
      state.publishing = false;
      nodes.submit.disabled = false;
    }
  }

  nodes.date.value = todayText();
  loadSettings();
  updateModeUi();

  nodes.title.addEventListener("input", refreshPath);
  nodes.date.addEventListener("input", refreshPath);
  nodes.owner.addEventListener("input", saveSettings);
  nodes.repo.addEventListener("input", saveSettings);
  nodes.branch.addEventListener("input", saveSettings);
  nodes.saveToken.addEventListener("change", saveSettings);
  nodes.token.addEventListener("input", () => {
    if (nodes.saveToken.checked) saveSettings();
  });

  nodes.mdToolbar.addEventListener("click", (event) => {
    const target = event.target;
    if (!(target instanceof Element)) return;

    const button = target.closest("button[data-md-action]");
    if (!(button instanceof HTMLButtonElement)) return;

    const action = String(button.dataset.mdAction || "");
    applyMarkdownAction(action);
  });

  nodes.previewFile.addEventListener("click", () => {
    refreshPath();
    setStatus("文件名预览已更新。", "ok");
  });

  nodes.loadPosts.addEventListener("click", async () => {
    await listPosts();
  });

  nodes.loadSelected.addEventListener("click", async () => {
    await loadSelectedPost();
  });

  nodes.deleteSelected.addEventListener("click", async () => {
    await deleteSelectedPost();
  });

  nodes.exitEdit.addEventListener("click", () => {
    stopEditing();
    setStatus("已退出编辑模式，当前为新建文章。", "ok");
  });

  form.addEventListener("submit", async (event) => {
    event.preventDefault();
    await publish();
  });

  if (nodes.token.value.trim() && nodes.owner.value.trim() && nodes.repo.value.trim()) {
    listPosts({ silent: true });
  }
})();
</script>

