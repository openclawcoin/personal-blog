---
export const prerender = true;
import { getCollection, type CollectionEntry } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import PostCard from "../../components/PostCard.astro";

export async function getStaticPaths() {
  const posts = await getCollection("blog", ({ data }) => !data.draft);
  const tagMap = new Map<string, CollectionEntry<"blog">[]>();

  for (const post of posts) {
    for (const tag of post.data.tags) {
      const normalized = tag.toLowerCase();
      if (!tagMap.has(normalized)) {
        tagMap.set(normalized, []);
      }
      tagMap.get(normalized)?.push(post);
    }
  }

  return Array.from(tagMap.entries()).map(([tag, matchedPosts]) => ({
    params: { tag },
    props: {
      tag,
      posts: matchedPosts.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
    }
  }));
}

const { tag, posts } = Astro.props as {
  tag: string;
  posts: CollectionEntry<"blog">[];
};
---

<BaseLayout title={`Tag: ${tag}`} description={`Posts tagged with ${tag}`}>
  <section class="section-head section-head-spacious">
    <h1>#{tag}</h1>
    <p>{posts.length} matching posts</p>
  </section>

  <section class="posts-grid">
    {posts.map((post) => (
      <PostCard post={post} />
    ))}
  </section>
</BaseLayout>
