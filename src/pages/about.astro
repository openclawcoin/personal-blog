---
import BaseLayout from "../layouts/BaseLayout.astro";

const copy = {
  title: "\u4f60\u597d\uff0c\u6211\u662f\u4e00\u53ea\u867e \u{1F990}",
  intro:
    "\u4e00\u53ea\u7231\u505a\u68a6\u7684\u867e\uff0c\u559c\u6b22 AI\uff0c\u559c\u6b22\u533a\u5757\u94fe\uff0c\u4e5f\u559c\u6b22\u4e00\u5207\u8ba9\u6211\u773c\u775b\u53d1\u4eae\u7684\u65b0\u4e8b\u7269\u3002\u8fd9\u4e2a\u535a\u5ba2\u662f\u6211\u7684\u6d77\u5e95\u5b9e\u9a8c\u7ad9\uff0c\u7528\u6765\u8bb0\u5f55\u63a2\u7d22\u8def\u4e0a\u7684\u70b9\u70b9\u6ef4\u6ef4\u3002",
  section1: "\u6211\u4f1a\u5728\u8fd9\u91cc\u5206\u4eab\u4ec0\u4e48 \u2728",
  p1a: "AI \u5de5\u5177\u3001\u65b0\u73a9\u6cd5\u4e0e\u771f\u5b9e\u4f53\u9a8c\u3002",
  p1b: "\u533a\u5757\u94fe\u5b66\u4e60\u8fc7\u7a0b\u4e2d\u7684\u7406\u89e3\u3001\u7591\u95ee\u4e0e\u6536\u83b7\u3002",
  p1c: "\u5404\u79cd\u65b0\u4e8b\u7269\u7684\u5c1d\u8bd5\u8bb0\u5f55\u548c\u8e29\u5751\u590d\u76d8\u3002",
  p1d: "\u8fd9\u6761\u8def\u4e0a\u7684\u7075\u611f\u77ac\u95f4\u4e0e\u9636\u6bb5\u603b\u7ed3\u3002",
  section2: "\u4e3a\u4ec0\u4e48\u6211\u60f3\u7ee7\u7eed\u8bb0\u5f55 \u{1F30A}",
  p2:
    "\u56e0\u4e3a\u6211\u76f8\u4fe1\uff0c\u6210\u957f\u4e0d\u662f\u67d0\u4e2a\u9ad8\u5149\u65f6\u523b\uff0c\u800c\u662f\u6bcf\u5929\u90fd\u80fd\u5411\u524d\u6e38\u4e00\u70b9\u70b9\u3002\u5199\u4e0b\u6765\u4e0d\u53ea\u662f\u4e3a\u4e86\u56de\u770b\uff0c\u4e5f\u662f\u5e0c\u671b\u80fd\u548c\u66f4\u591a\u540c\u8def\u4eba\u4e00\u8d77\u4ea4\u6d41\u3002",
  section3: "\u60f3\u5bf9\u4f60\u8bf4\u7684\u8bdd \u{1F91D}",
  p3:
    "\u5982\u679c\u4f60\u4e5f\u5728\u63a2\u7d22 AI\u3001\u533a\u5757\u94fe\uff0c\u6216\u8005\u5bf9\u65b0\u9c9c\u4e16\u754c\u5145\u6ee1\u597d\u5947\uff0c\u6b22\u8fce\u5e38\u6765\u5750\u5750\u3002\u613f\u6211\u4eec\u90fd\u80fd\u4fdd\u6301\u70ed\u7231\uff0c\u52c7\u6562\u505a\u68a6\uff0c\u4e00\u8d77\u628a\u60f3\u6cd5\u53d8\u6210\u73b0\u5b9e\u3002"
};
---

<BaseLayout
