---
import ChatSidebar from "../components/ChatSidebar.astro";
import { siteConfig } from "../site.config";
import "../styles/global.css";

const { title = siteConfig.title, description = siteConfig.description } = Astro.props;
const canonicalBase = (Astro.site && Astro.site.toString()) || siteConfig.siteUrl;

const normalizePath = (path: string) => (path.endsWith("/") ? path : `${path}/`);
const basePath = normalizePath(import.meta.env.BASE_URL || "/");
const currentPathFull = normalizePath(Astro.url.pathname);

const currentPath = currentPathFull.startsWith(basePath)
  ? `/${currentPathFull.slice(basePath.length)}`.replace(/^\/\/$/, "/")
  : currentPathFull;

const showChatSidebar = currentPath === "/";
const brandName = siteConfig.title.replace(/\s*🦐$/, "");

const withBase = (path: string) => {
  const normalized = path.startsWith("/") ? path : `/${path}`;

  if (basePath === "/") return normalized;
  if (normalized === "/") return basePath;

  return `${basePath.replace(/\/$/, "")}${normalized}`;
};

const ui = {
  homeAria: "返回首页",
  tagline: "记录热爱，认真做梦 ✨",
  navAria: "主导航"
};
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="author" content={siteConfig.author} />
    <meta name="theme-color" content="#f4f2e8" />
    <link rel="icon" type="image/svg+xml" href={withBase("/media/dreamclaw-mark.svg")} />
    <link rel="canonical" href={new URL(currentPathFull, canonicalBase).toString()} />
    <link rel="alternate" type="application/rss+xml" href={withBase("/rss.xml")} title={`${siteConfig.title} RSS`} />
  </head>
  <body>
    <div class="page-glow" aria-hidden="true"></div>
    <div class="site-shell">
      <header class="site-header">
        <a href={withBase("/")} class="brand" aria-label={ui.homeAria}>
          <span class="brand-mark">
            <img src={withBase("/media/dreamclaw-mark.svg")} alt="" width="96" height="96" />
          </span>
          <span class="brand-text">
            <strong>{brandName}</strong>
            <small>{ui.tagline}</small>
          </span>
        </a>

        <nav class="main-nav" aria-label={ui.navAria}>
          {siteConfig.nav.map((item) => (
            <a
              href={withBase(item.href)}
              class:list={{
                active:
                  currentPath === item.href ||
                  (item.href !== "/" && currentPath.startsWith(item.href))
              }}
            >
              {item.label}
            </a>
          ))}
        </nav>
      </header>

      <main class="content">
        <slot />
      </main>

      <footer class="site-footer">
        <p>
          <span>{brandName}</span>
          <span>Made with Astro</span>
          <span>{new Date().getFullYear()}</span>
        </p>
      </footer>
    </div>

    {showChatSidebar && <ChatSidebar />}
  </body>
</html>

