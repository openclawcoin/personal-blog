      <button type="button" aria-label="下一月" data-cal-next>›</button>
    </div>

    <div class="calendar-week">
      <span>日</span><span>一</span><span>二</span><span>三</span><span>四</span><span>五</span><span>六</span>
    </div>

    <div class="calendar-grid" data-cal-grid></div>

    <p class="calendar-note">有文章的日期可点击直达当天博客</p>
    <script type="application/json" data-post-index>{postIndexJson}</script>
  </article>
</section>

<script is:inline>
(() => {
  const root = document.querySelector("[data-left-calendar]");
  if (!root) return;

  const indexNode = root.querySelector("[data-post-index]");
  const titleNode = root.querySelector("[data-cal-title]");
  const gridNode = root.querySelector("[data-cal-grid]");
  const prevBtn = root.querySelector("[data-cal-prev]");
  const nextBtn = root.querySelector("[data-cal-next]");

  if (!titleNode || !gridNode || !prevBtn || !nextBtn || !indexNode) return;

  let postIndex = {};
  try {
    postIndex = JSON.parse(indexNode.textContent || "{}");
  } catch {
    postIndex = {};
  }

  const cursor = new Date();
  cursor.setDate(1);

  function dateKey(year, month, day) {
    return `${year}-${String(month + 1).padStart(2, "0")}-${String(day).padStart(2, "0")}`;
  }

  function render() {
    const year = cursor.getFullYear();
    const month = cursor.getMonth();

    titleNode.textContent = `${year} 年 ${month + 1} 月`;
    gridNode.innerHTML = "";

    const firstDay = new Date(year, month, 1).getDay();
    const daysInMonth = new Date(year, month + 1, 0).getDate();

    const today = new Date();
    const todayKey = dateKey(today.getFullYear(), today.getMonth(), today.getDate());

    for (let i = 0; i < firstDay; i += 1) {
      const blank = document.createElement("span");
      blank.className = "calendar-cell calendar-empty";
      blank.textContent = "";
      gridNode.append(blank);
    }

    for (let day = 1; day <= daysInMonth; day += 1) {
      const key = dateKey(year, month, day);
      const post = postIndex[key];

      let node;
      if (post && post.slug) {
        node = document.createElement("a");
        node.href = `/blog/${post.slug}/`;
        node.title = post.title || "查看文章";
        node.className = "calendar-cell has-post";
      } else {
        node = document.createElement("span");
        node.className = "calendar-cell";
      }

      if (key === todayKey) {
        node.classList.add("today");
      }

      node.textContent = String(day);
      gridNode.append(node);
    }
  }

  prevBtn.addEventListener("click", () => {
    cursor.setMonth(cursor.getMonth() - 1);
    render();
  });

  nextBtn.addEventListener("click", () => {
    cursor.setMonth(cursor.getMonth() + 1);
    render();
  });

  render();
})();
</script>

