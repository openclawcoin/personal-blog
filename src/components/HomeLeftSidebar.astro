---
type CalendarPost = {
  date: string;
  slug: string;
  title: string;
};

const { posts = [] } = Astro.props as { posts: CalendarPost[] };

const postMap: Record<string, { slug: string; title: string }> = {};
for (const post of posts) {
  if (!postMap[post.date]) {
    postMap[post.date] = { slug: post.slug, title: post.title };
  }
}

const postIndexJson = JSON.stringify(postMap);
---

