{
  "name": "personal-blog",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "astro dev",
    "start": "astro dev",
    "build": "astro build",
    "prebuild": "npm run sync:blog-media && npm run check:posts",
    "postbuild": "node scripts/sync-blog-media.mjs dist-blog",
    "preview": "astro preview",
    "check": "astro check",
    "check:posts": "node scripts/validate-blog-frontmatter.mjs",
    "sync:blog-media": "node scripts/sync-blog-media.mjs public-src",
    "new:daily": "powershell -ExecutionPolicy Bypass -File scripts/new-daily-post.ps1"
  },
  "dependencies": {
    "astro": "^5.0.0"
  },
  "devDependencies": {
    "typescript": "^5.7.0"
  }
}